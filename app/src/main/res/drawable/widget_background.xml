<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Bottom-right shadow -->
    <item
        android:left="2dp"
        android:top="2dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/neu_shadow" />
            <corners android:radius="22dp" />
        </shape>
    </item>
    <!-- Top-left highlight -->
    <item
        android:right="2dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/neu_highlight" />
            <corners android:radius="22dp" />
        </shape>
    </item>
    <!-- Main surface -->
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/neu_background" />
            <corners android:radius="20dp" />
            <stroke
                android:width="1dp"
                android:color="@color/neu_border" />
        </shape>
    </item>
</layer-list>
